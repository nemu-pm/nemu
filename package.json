{
  "name": "nemu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host\" \"convex dev\"",
    "build": "tsx scripts/generate-apple-secret.ts && tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit && tsc -p convex --noEmit",
    "preview": "vite preview",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "service": "bun service/dev.ts",
    "generate:apple-secret": "tsx scripts/generate-apple-secret.ts",
    "predeploy": "bun run generate:apple-secret",
    "deploy": "bun run predeploy && convex deploy"
  },
